# Copy this file to `.env` and fill in values locally. Never commit `.env`.

# Optional: Google AI Studio key for Gemini polish (uses google-genai SDK, see README).
GEMINI_API_KEY=

# Set to 1 to attach live ESPN public JSON (headlines / standings) alongside demo files.
FANDRAGEN_LIVE_ESPN=0

# Set to 1 to merge real stats.nba.com game logs via nba_api (see data/demo/nba_player_map.json).
FANDRAGEN_NBA_API=0

# Optional: NBA season string for PlayerGameLog, e.g. 2024-25 (defaults from nba_player_map.json).
# NBA_STATS_SEASON=2024-25

# Optional: verbose logging (Gemini + enrichment diagnostics).
# FANDRAGEN_DEBUG=1
