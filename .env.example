# Copy this file to `.env` and fill in values locally. Never commit `.env`.

# Optional: Google AI Studio key for Gemini polish (uses google-genai SDK, see README).
GEMINI_API_KEY=
# Optional: pin one model (recommended: gemini-2.5-flash — fewer 404/429 issues than 2.0 on free tier).
GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to attach live ESPN public JSON (headlines / standings) alongside local data.
FANDRAGEN_LIVE_ESPN=0

# Set to 1 to merge real stats.nba.com game logs via nba_api. Rows may include kaggle_nba_person_id from the CSV.
FANDRAGEN_NBA_API=0

# Optional: NBA season string for PlayerGameLog, e.g. 2024-25 (defaults to 2024-25 when no nba_player_map.json).
# NBA_STATS_SEASON=2024-25

# Required for runtime: path to the Kaggle-format NBA season stats CSV (absolute or relative to project root).
# Default if unset: data/kaggle/nba_player_stats_2425.csv — place the downloaded file there.
# Dataset: https://www.kaggle.com/datasets/eduardopalmieri/nba-player-stats-season-2425
FANDRAGEN_KAGGLE_NBA_CSV=data/kaggle/nba_player_stats_2425.csv

# Optional: verbose logging (Gemini + enrichment diagnostics).
# FANDRAGEN_DEBUG=1
